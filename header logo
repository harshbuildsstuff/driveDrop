<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 480 160" width="480" height="160">
  <defs>
    <radialGradient id="bgGlow" cx="25%" cy="50%" r="60%">
      <stop offset="0%" stop-color="#0a2a6e" stop-opacity="0.9"/>
      <stop offset="100%" stop-color="#01030d" stop-opacity="1"/>
    </radialGradient>
    <linearGradient id="iconGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0a2a6e"/>
      <stop offset="100%" stop-color="#4a9eff"/>
    </linearGradient>
    <linearGradient id="glowLine" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#4a9eff" stop-opacity="0"/>
      <stop offset="50%" stop-color="#00d4ff" stop-opacity="0.8"/>
      <stop offset="100%" stop-color="#4a9eff" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="driveGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#7ec8ff"/>
      <stop offset="100%" stop-color="#a5f3fc"/>
    </linearGradient>
    <linearGradient id="dropGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#00d4ff"/>
      <stop offset="100%" stop-color="#4a9eff"/>
    </linearGradient>
    <filter id="softGlow" x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="iconGlow" x="-40%" y="-40%" width="180%" height="180%">
      <feGaussianBlur stdDeviation="6" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <clipPath id="roundedBox">
      <rect x="0" y="0" width="480" height="160" rx="20" ry="20"/>
    </clipPath>
  </defs>

  <rect width="480" height="160" rx="20" ry="20" fill="url(#bgGlow)"/>

  <g clip-path="url(#roundedBox)">
    <circle cx="30"  cy="20"  r="1.2" fill="#7ec8ff" opacity="0.7"/>
    <circle cx="80"  cy="8"   r="0.8" fill="#ffffff"  opacity="0.5"/>
    <circle cx="140" cy="14"  r="1"   fill="#a5f3fc"  opacity="0.6"/>
    <circle cx="210" cy="5"   r="0.7" fill="#ffffff"  opacity="0.4"/>
    <circle cx="270" cy="11"  r="1.1" fill="#7ec8ff"  opacity="0.5"/>
    <circle cx="330" cy="6"   r="0.9" fill="#ffffff"  opacity="0.6"/>
    <circle cx="390" cy="17"  r="1.3" fill="#a5f3fc"  opacity="0.5"/>
    <circle cx="445" cy="9"   r="0.8" fill="#ffffff"  opacity="0.4"/>
    <circle cx="462" cy="32"  r="1"   fill="#7ec8ff"  opacity="0.6"/>
    <circle cx="415" cy="142" r="0.9" fill="#ffffff"  opacity="0.3"/>
    <circle cx="355" cy="150" r="1.1" fill="#7ec8ff"  opacity="0.4"/>
    <circle cx="52"  cy="148" r="1"   fill="#ffffff"  opacity="0.3"/>
    <circle cx="105" cy="154" r="0.8" fill="#7ec8ff"  opacity="0.4"/>
  </g>

  <rect x="0" y="0" width="480" height="160" rx="20" ry="20"
        fill="none" stroke="rgba(74,158,255,0.2)" stroke-width="1"/>

  <rect x="40" y="0" width="220" height="1" rx="1" fill="url(#glowLine)" opacity="0.5"/>

  <rect x="18" y="18" width="84" height="84" rx="18" fill="url(#iconGrad)"
        filter="url(#iconGlow)" opacity="0.95"/>
  <rect x="18" y="18" width="84" height="84" rx="18"
        fill="none" stroke="rgba(74,158,255,0.4)" stroke-width="1"/>
  <rect x="19" y="19" width="82" height="2" rx="1" fill="rgba(255,255,255,0.07)"/>

  <text x="60" y="72" font-size="44" text-anchor="middle" dominant-baseline="middle">🛸</text>

  <text x="60" y="113" font-size="9" text-anchor="middle"
        fill="rgba(0,212,255,0.45)" font-family="monospace" letter-spacing="3">✦ ✦ ✦</text>

  <rect x="18" y="114" width="84" height="28" rx="8"
        fill="rgba(0,212,255,0.06)" stroke="rgba(0,212,255,0.15)" stroke-width="1"/>

  <text x="33" y="128.5" font-size="7.5" text-anchor="middle" dominant-baseline="middle"
        font-family="'Courier New', monospace" font-weight="bold" letter-spacing="0.5"
        fill="rgba(0,212,255,0.7)">DD</text>

  <line x1="42" y1="118" x2="42" y2="140" stroke="rgba(0,212,255,0.2)" stroke-width="0.6"/>

  <g stroke-linecap="round" stroke-linejoin="round" fill="none" stroke-width="1.6">
    <line x1="55"  y1="132" x2="55"  y2="122" stroke="#ff3b30"/>
    <line x1="55"  y1="132" x2="51"  y2="128" stroke="#ff3b30"/>
    <line x1="55"  y1="132" x2="59"  y2="128" stroke="#ff3b30"/>

    <line x1="67"  y1="122" x2="67"  y2="132" stroke="#30d158"/>
    <line x1="67"  y1="122" x2="63"  y2="126" stroke="#30d158"/>
    <line x1="67"  y1="122" x2="71"  y2="126" stroke="#30d158"/>
  </g>

  <text x="126" y="60"
        font-family="'Courier New', monospace"
        font-size="40" font-weight="900" letter-spacing="-1"
        fill="url(#driveGrad)" filter="url(#softGlow)">Drive</text>

  <text x="282" y="60"
        font-family="'Courier New', monospace"
        font-size="40" font-weight="900" letter-spacing="-1"
        fill="url(#dropGrad)" filter="url(#softGlow)">Drop</text>

  <line x1="126" y1="70" x2="432" y2="70"
        stroke="url(#glowLine)" stroke-width="0.8" opacity="0.35"/>

  <text x="128" y="90"
        font-family="'Courier New', monospace"
        font-size="10.5" letter-spacing="3.5"
        fill="rgba(74,158,255,0.65)">BEAM IT. FREE IT. FORGET IT.</text>

  <text x="130" y="118"
        font-family="'Courier New', monospace"
        font-size="9" letter-spacing="2"
        fill="rgba(0,212,255,0.3)">🌌 interstellar file transfer</text>

  <circle cx="126" cy="60" r="2.5" fill="#00d4ff" opacity="0.5" filter="url(#softGlow)"/>
  <circle cx="126" cy="60" r="5.5" fill="none" stroke="#00d4ff" stroke-width="0.5" opacity="0.25"/>

  <text x="438" y="52" font-size="14" opacity="0.3">🗃</text>
  <text x="436" y="78" font-size="12" opacity="0.2">👾</text>
</svg>

